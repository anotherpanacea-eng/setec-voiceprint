{
  "compute": {
    "cost_note": "$0.05\u20130.30 per doc via Anthropic / OpenAI / Gemini; free with --judge manifest",
    "length_floor_words": 2000,
    "tier": "api_llm"
  },
  "consumers": [
    "apodictic",
    "setec-voicewright"
  ],
  "dependencies": {
    "python": [],
    "python_optional": [],
    "sdks_optional": [
      "anthropic",
      "openai",
      "google-genai"
    ]
  },
  "do_not_use_when": [
    "Target is an essay, op-ed, or under ~2000 words",
    "You need a binary verdict from one audit alone",
    "You don't have access to an LLM judge (or a pre-computed feature manifest)"
  ],
  "examples": [
    {
      "cmd": "python3 plugins/setec-voiceprint/scripts/narrative_decision_audit.py story.txt --judge manifest --judge-manifest features.json",
      "description": "Single-doc audit with pre-computed values"
    },
    {
      "cmd": "python3 plugins/setec-voiceprint/scripts/narrative_decision_audit.py story.txt --judge anthropic --judge-model claude-sonnet-4-6",
      "description": "Direct API spot-check"
    }
  ],
  "family": "narrative-decision",
  "handoff": "experimental",
  "id": "narrative_decision_audit",
  "inputs": [
    {
      "flag": "target",
      "type": "path",
      "required": true
    },
    {
      "flag": "--judge",
      "type": "enum",
      "required": false,
      "values": [
        "manifest",
        "mock",
        "anthropic",
        "openai",
        "gemini"
      ]
    },
    {
      "flag": "--judge-manifest",
      "type": "path",
      "required": false
    },
    {
      "flag": "--judge-model",
      "type": "string",
      "required": false
    },
    {
      "flag": "--json",
      "type": "bool",
      "required": false
    }
  ],
  "outputs": {
    "artifacts": [
      ".narrative.json",
      ".narrative.md"
    ],
    "schema_version": "1.0"
  },
  "purpose": "Score a story's narrative decisions (themes, plot, pacing, sensory register, reader engagement) against Russell et al. 2026's reported human / AI group means. Distinct from the texture-level AIC families \u2014 these are discourse-level decisions that require structural rewrites to remove.\n",
  "references": [
    "plugins/setec-voiceprint/references/narrative-decision-audit-spec.md",
    "plugins/setec-voiceprint/references/narrative-decision-replication-spec.md",
    "plugins/setec-voiceprint/references/storyscope-prompts/",
    "plugins/setec-voiceprint/references/apodictic-handoff-storyscope.md"
  ],
  "registers": [
    "long_form_fiction"
  ],
  "script_path": "plugins/setec-voiceprint/scripts/narrative_decision_audit.py",
  "status": "literature_anchored",
  "surface": "narrative_decision_audit",
  "use_when": [
    "Target is long-form fiction \u2265 2000 words",
    "You want evidence that survives LAMP-style stylistic rewriting",
    "You're stacking signals with Tier 1 / AIC / Binoculars"
  ],
  "min_setec_version": "1.107.0",
  "json_delivery": "stdout"
}
